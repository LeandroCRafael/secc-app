{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secc.example/schemas/operational/proposal-v1.json",
  "title": "SECC Proposal v1",
  "type": "object",
  "required": ["id", "companyId", "year", "variable", "unit", "availability", "source", "status", "createdBy", "createdAt", "version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "companyId": { "type": "string", "minLength": 1 },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2200 },
    "variable": { "type": "string", "minLength": 2 },
    "value": { "type": ["number", "string", "null"] },
    "unit": { "enum": ["BRL", "BRL_millions", "percent", "count", "count_millions", "text"] },
    "availability": { "enum": ["available", "not_researched", "unavailable", "not_applicable", "future_period", "withheld", "under_review", "conflicted", "rejected"] },
    "status": { "enum": ["draft", "submitted", "under_review", "approved", "rejected", "synchronized", "published", "conflicted"] },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": true
}
