{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secc.example/schemas/excel/sync-batch-v2.json",
  "title": "SECC Excel Sync Batch v2",
  "type": "object",
  "required": [
    "id",
    "idempotencyKey",
    "workbookId",
    "sourceSnapshotId",
    "status",
    "mappingVersion",
    "sourceWorkbookVersion",
    "resultWorkbookVersion",
    "sourceSha256",
    "approvedCount",
    "readyCount",
    "conflictCount",
    "unmappedCount",
    "unchangedCount",
    "excelChangeCount",
    "requestedBy",
    "requestedAt",
    "backupFileName"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 64, "maxLength": 64 },
    "workbookId": { "type": "string", "minLength": 1 },
    "sourceSnapshotId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["prepared", "blocked", "applied", "failed"] },
    "mappingVersion": { "type": "string", "minLength": 1 },
    "sourceWorkbookVersion": { "type": "string", "minLength": 1 },
    "resultWorkbookVersion": { "type": "string", "minLength": 1 },
    "sourceSha256": { "type": "string", "minLength": 64, "maxLength": 64 },
    "resultSha256": { "type": ["string", "null"] },
    "approvedCount": { "type": "integer", "minimum": 0 },
    "readyCount": { "type": "integer", "minimum": 0 },
    "conflictCount": { "type": "integer", "minimum": 0 },
    "unmappedCount": { "type": "integer", "minimum": 0 },
    "unchangedCount": { "type": "integer", "minimum": 0 },
    "excelChangeCount": { "type": "integer", "minimum": 0 },
    "requestedBy": { "type": "string", "minLength": 1 },
    "requestedAt": { "type": "string", "format": "date-time" },
    "appliedBy": { "type": ["string", "null"] },
    "appliedAt": { "type": ["string", "null"], "format": "date-time" },
    "outputFileName": { "type": ["string", "null"] },
    "backupFileName": { "type": "string", "minLength": 1 },
    "failureReason": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
