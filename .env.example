# PostgreSQL local. Preencher apenas em .env.local.
DATABASE_URL=

# Identidade e autenticação do único administrador local.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Diretórios locais privados. Usar caminhos relativos, nunca caminhos pessoais absolutos.
APP_DATA_DIR=
PRIVATE_STORAGE_DIR=
PUBLIC_RELEASE_DIR=

# Força o modo público seguro fora da Vercel. Em produção ele já é ativado por padrão.
PUBLIC_PREVIEW=

# Dashboard interno publicado. Exige autenticação HTTP e snapshot protegido na Vercel.
INTERNAL_DASHBOARD_ENABLED=
INTERNAL_ACCESS_USER=
INTERNAL_ACCESS_PASSWORD=
INTERNAL_DIAGNOSTICS_SNAPSHOT=

# Configuração futura do Microsoft Graph, inativa enquanto o arquivo estiver em OneDrive pessoal.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
